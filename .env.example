DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/erp_solution?schema=public"
PORT=3000
NODE_ENV=development
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
THROTTLE_TTL=60
THROTTLE_LIMIT=100
SWAGGER_PATH="api-docs"
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="alerts@example.com"
USER_PROVISIONING_PASSWORD_MODE="static"  #static, random
USER_PROVISIONING_STATIC_PASSWORD=""
USER_PROVISIONING_RANDOM_PASSWORD_LENGTH=12